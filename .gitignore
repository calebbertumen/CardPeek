# See https://help.github.com/articles/ignoring-files/

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment & secrets — copy .env.example → .env locally; never commit real values
.env
.env.*
!.env.example

# Secret / credential files (common tooling)
*credentials*.json
*.pem.key

# direnv (often exports DATABASE_URL and other secrets)
.envrc

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# tooling caches
.turbo
.cache

# IDE / OS (local paths or tokens in some setups)
.idea/
