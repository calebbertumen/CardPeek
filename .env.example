# Copy to .env and fill in values. Do not commit .env — it is gitignored.

# PostgreSQL (Prisma)
# Local Postgres: use the same connection string for both.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/cardpeek"
DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/cardpeek"
#
# Supabase (Connect → ORM → Prisma): copy both strings from the dashboard.
# - DATABASE_URL = Transaction pooler (port 6543): you MUST append ?pgbouncer=true (and sslmode=require if missing).
#   Without pgbouncer=true, Prisma on Vercel often throws: prepared statement "sN" does not exist (Postgres 26000).
# - DIRECT_URL   = Session pooler URI (IPv4-friendly) for `npm run db push` from your Mac.
#   Direct `db.*.supabase.co:5432` often fails from home networks (IPv6); session pooler fixes that.
# Vercel: set DATABASE_URL to the transaction pooler; set DIRECT_URL to the same session pooler
# (or any reachable URL) — runtime uses DATABASE_URL; directUrl is mainly for schema commands.

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret"

# Optional; inferred in many deployments (set in production if redirects break)
# AUTH_URL="http://localhost:3000"

# Password reset emails (Resend — https://resend.com)
# RESEND_API_KEY=
# From address: must use a domain you verified in Resend (DNS). The default
#   CardPeek <onboarding@resend.dev>
# only works for limited testing; for real users you must add your domain and set e.g.:
# RESEND_FROM_EMAIL="CardPeek <reset@yourdomain.com>"
# If mail never arrives, check the Resend dashboard → Emails for API errors, and check spam.
# In development, if RESEND_API_KEY is unset, the reset URL is printed in the Next.js terminal.
# Temporary debugging on Vercel: set PASSWORD_RESET_DEBUG=true to show Resend errors on the forgot-password form (remove after fixing).
# Public origin for links in emails (production: your real domain)
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional — higher rate limits for Pokémon TCG API v2
# POKEMON_TCG_API_KEY=""

# Optional — uncapped anonymous searches (limits are off automatically in NODE_ENV=development)
# DISABLE_ANONYMOUS_SEARCH_LIMIT=true

# Stripe — billing amount is defined on the Price in Stripe (set Collector to $6.99/mo there)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_COLLECTOR_PRICE_ID=
# NEXT_PUBLIC_APP_URL=http://localhost:3000
#
# Local webhook (test mode): run Next on :3000, then in another terminal:
#   stripe listen --forward-to localhost:3000/api/stripe/webhook
# Copy the printed "whsec_..." into STRIPE_WEBHOOK_SECRET and restart `npm run dev`.
#
# In Stripe Dashboard → Webhooks, enable at least:
#   checkout.session.completed, invoice.paid, customer.subscription.created,
#   customer.subscription.updated, customer.subscription.deleted
# (`invoice.paid` is required to record firstCollectorPaymentIntentId for refunds.)

# Optional — matches display defaults; Stripe still charges the Price attached to STRIPE_COLLECTOR_PRICE_ID
# COLLECTOR_PRICE_MONTHLY_USD=6.99

# Apify — eBay sold listings (caffein.dev/ebay-sold-listings)
# APIFY_TOKEN=
# Default actor id: owner~actor-name (Apify store: caffein.dev/ebay-sold-listings → caffein.dev~ebay-sold-listings)
# APIFY_EBAY_SOLD_ACTOR_ID=caffein.dev~ebay-sold-listings
# Max time for the initial Apify HTTP wait; if the actor runs longer, the app polls until SUCCEEDED (see ebay-sold-listings actor).
# APIFY_WAIT_FOR_FINISH_SEC=120
# APIFY_EBAY_SOLD_DAYS_TO_SCRAPE=14
# APIFY_EBAY_SITE=ebay.com
# Skip HTML preflight that avoids storing “similar” eBay results when there are no exact matches (set true only if eBay blocks server fetches).
# EBAY_SKIP_NO_EXACT_MATCH_PREFLIGHT=false
# Optional — visits each sold item page (slower / more Apify usage). Actor may expose extra fields; images are also filled server-side from listing HTML when missing.
# APIFY_EBAY_DETAILED_SEARCH=false
# Sold pipeline: one Apify run = up to 8 rows; map + dedupe; return up to 5 (never re-scrape to pad).
# Set true only for debugging (stores raw actor rows on CardCacheListing)
# SCRAPING_STORE_RAW_PAYLOAD=false

# Scraping provider: mock (default in dev) or apify for production sold listings
# SCRAPING_PROVIDER=apify

#
