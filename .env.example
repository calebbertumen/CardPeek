# Copy to .env and fill in values. Do not commit .env — it is gitignored.

# PostgreSQL connection (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/cardpeek"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret"

# Optional; inferred in many deployments (set in production if redirects break)
# AUTH_URL="http://localhost:3000"

# Optional — higher rate limits for Pokémon TCG API v2
# POKEMON_TCG_API_KEY=""

# Optional — uncapped anonymous searches (limits are off automatically in NODE_ENV=development)
# DISABLE_ANONYMOUS_SEARCH_LIMIT=true

# Stripe — billing amount is defined on the Price in Stripe (set Collector to $6.99/mo there)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_COLLECTOR_PRICE_ID=
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional — matches display defaults; Stripe still charges the Price attached to STRIPE_COLLECTOR_PRICE_ID
# COLLECTOR_PRICE_MONTHLY_USD=6.99

# Internal — Starter hidden market lookups per UTC day when sold cache is missing (0 = off; not shown in UI)
# STARTER_HIDDEN_LIVE_FETCHES_PER_DAY=1
